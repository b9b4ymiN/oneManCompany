{
  "name": "onemancompany",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint packages vitest.config.ts --ext .ts --ignore-pattern '**/dist/**'",
    "format": "prettier --write \"packages/**/*.{ts,md}\" package.json eslint.config.mjs prettier.config.mjs tsconfig.base.json tsconfig.json vitest.config.ts pnpm-workspace.yaml",
    "format:check": "prettier --check \"packages/**/*.{ts,md}\" package.json eslint.config.mjs prettier.config.mjs tsconfig.base.json tsconfig.json vitest.config.ts pnpm-workspace.yaml",
    "test": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.25.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "typescript-eslint": "^8.30.1",
    "@types/better-sqlite3": "^7.6.12"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "drizzle-orm": "^0.44.2",
    "js-yaml": "^4.1.0",
    "neverthrow": "^8.2.0",
    "winston": "^3.17.0",
    "zod": "^3.24.4",
    "commander": "^13.1.0"
  }
}
